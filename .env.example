# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Exemplo para MySQL local:
DATABASE_URL=mysql://root:suasenha@localhost:3306/labscheduler

# ─── Segurança ────────────────────────────────────────────────────────────────
# Chave secreta para assinar os tokens JWT (mínimo 32 caracteres)
JWT_SECRET=mude-esta-chave-secreta-para-producao-min-32-chars

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Notificações Microsoft Teams (opcional) ──────────────────────────────────
# Configure o webhook por usuário no painel Admin > Usuários
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
